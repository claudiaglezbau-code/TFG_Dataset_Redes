        "    print(\"  PASO 4 — Entrenamiento (arquitectura Bayesian: 1 × 512, ReLU)\")\n",
        "    print(\"  Pipeline V3: split por paramset, 400k filas, sesgo, tf.function\")\n",
        "    print(\"═\" * 55)\n",
        "    model = construir_red(\n",
        "        input_dim=X_train.shape[1],\n",
        "        capas_config=ARCH_BAYESIAN,\n",
