        "    print(\"  model = construir_red(input_dim=X_train.shape[1], capas_config=ARCH_MANUAL_V3)\")\n",
        "\n",
        "    history = model.fit(\n",
        "        X_train, y_train,\n",
        "        validation_data=(X_val, y_val),\n",
        "        epochs=300,\n",
        "        batch_size=512,\n",
        "        callbacks=get_callbacks(),\n",
        "        verbose=1\n",
        "    )\n",
        "\n",
        "    print(\"\\n\" + \"═\" * 55)\n",
        "    print(\"  PASO 5 — Evaluación sobre test\")\n",
        "    print(\"═\" * 55)\n",
        "    metricas = evaluar_modelo(model, X_val, y_val, X_test, y_test, history=history)\n",
