        "    t_exacto = np.mean(tiempos_exacto)\n",
        "\n",
        "    # Red neuronal: compilar grafo + warmup, luego medir\n",
        "    print(\"  Compilando grafo tf.function (primera vez tarda ~1s)...\")\n",
        "    inferir_fn = compilar_inferencia(model)\n",
